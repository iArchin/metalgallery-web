# Trims the build context and, more importantly, keeps the live database out of
# every image layer.

# Reinstalled cleanly by `npm ci`. The host tree is Windows-built and carries
# the wrong sharp binary for Linux.
node_modules
**/node_modules

# Regenerated by `next build`; never ship a stale trace.
.next
out
build

# The LIVE runtime database: real orders, customer phone numbers, uploaded
# avatars. Image layers are trivially extractable, so this must never be baked.
# The build reads the scrubbed data.seed/ instead (see Dockerfile), and at run
# time the mg_data volume supplies the real thing.
#
# The trailing slash matters: it matches the data/ directory only, leaving
# data.seed/ — which MUST be in the context — alone.
/data/

# Secrets. The container gets its environment from compose's env_file at run
# time, never from a layer.
.env
.env.*
!.env.example

.git
.gitignore
*.tsbuildinfo
next-env.d.ts

# Deployment assets live on the server, not in the app image.
deploy/

# Editor / OS noise
.vscode
.idea
.DS_Store
Thumbs.db
npm-debug.log*
