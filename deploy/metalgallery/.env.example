# Copy to /srv/metalgallery/.env and `chmod 600` it. Never commit the real file.
#
#   cp .env.example .env && chmod 600 .env

# ---------------------------------------------------------------------------
# Required. The app refuses to boot without this.
# ---------------------------------------------------------------------------
# Signs every session cookie and salts every stored OTP hash. Generate one:
#
#     openssl rand -hex 32
#
# Must be at least 32 characters and must not be the development fallback
# string that lives in lib/server/secret.ts. Changing it logs everyone out.
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Database (PostgreSQL). Required — the app refuses to boot without it.
# ---------------------------------------------------------------------------
# The `db` service reads POSTGRES_*; the app reads DATABASE_URL. Keep them in
# sync — same user, password and db name. Generate the password once:
#
#     openssl rand -hex 24
#
POSTGRES_USER=metalgallery
POSTGRES_PASSWORD=
POSTGRES_DB=metalgallery
# Host is the compose service name `mg-db`. Must match the three values above.
DATABASE_URL=postgres://metalgallery:CHANGE_ME@mg-db:5432/metalgallery

# ---------------------------------------------------------------------------
# Hosts
# ---------------------------------------------------------------------------
# Serves the admin panel at the root of this host, and redirects
# metalgallery.ir/admin to it. Unset it and the panel falls back to /admin.
ADMIN_HOST=admin.metalgallery.ir

# Read at BUILD time, not run time — it is inlined into the browser bundle
# (app/admin/_components/AdminShell.tsx is a client component). It lives here
# only so deploy.sh can pass it as a --build-arg. Editing this file and
# restarting will NOT change it; you must rebuild the image.
NEXT_PUBLIC_SITE_URL=https://metalgallery.ir

# ---------------------------------------------------------------------------
# SMS OTP (SMS.ir). Login — customer AND admin — is impossible without it.
# ---------------------------------------------------------------------------
# The sandbox key only delivers to numbers registered in your SMS.ir panel, and
# sandbox template 123456 is for testing. Use production credentials here and
# make sure your template is approved.
#
# Locally, leave SMS_IR_API_KEY empty: the login form then shows the code
# on screen instead of sending an SMS. With any key set, the code is
# server-side only (console) — the same behaviour as production.
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=
SMS_IR_PARAM_NAME=Code

# ---------------------------------------------------------------------------
# Runtime. These match the image defaults; keep them unless you know why not.
# ---------------------------------------------------------------------------
NODE_ENV=production
DATA_DIR=/app/data
TZ=Asia/Tehran
