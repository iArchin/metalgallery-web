# Local development. For the server, see deploy/metalgallery/.env.example.
#
#   cp .env.example .env.local

# --- Database -----------------------------------------------------------------
# Postgres connection string. REQUIRED even in dev: without it, boot skips
# migrations but the first-boot import still queries the fallback database and
# the server exits. Create the database once (createdb metalgallery), set this,
# and boot migrates the schema and seeds an empty database from data.seed/.
DATABASE_URL=postgres://localhost:5432/metalgallery

# --- Session secret -----------------------------------------------------------
# Signs session cookies and salts stored OTP hashes. Optional in development —
# lib/server/secret.ts falls back to a fixed dev string. In production the app
# REFUSES TO BOOT unless this is set, at least 32 chars, and not the fallback.
#
#   openssl rand -hex 32
SESSION_SECRET=

# --- SMS OTP (SMS.ir) ---------------------------------------------------------
# Leave SMS_IR_API_KEY empty locally: no SMS is sent and the login form shows
# the code on screen. Set any key and the app behaves like production — the code
# goes to the server console only, never to the browser.
#
# With a key set, the code goes out over BOTH paths below in parallel (each one
# is optional, but configure both — see sendVerifySms in lib/server/otp.ts):
#   - SMS_IR_LINE_NUMBER: a dedicated line, delivers in seconds. Unless the
#     line is a SERVICE line (خدماتی), the carrier silently drops its messages
#     to numbers on the national ad-SMS opt-out list.
#   - SMS_IR_TEMPLATE_ID: the approved verify template on SMS.ir's shared
#     service line. Reaches every number, but can take minutes.
# SMS_IR_OTP_MESSAGE overrides the dedicated-line text ({code} = the code).
# Keep it URL-free: carriers filter link-bearing SMS on a non-service line.
SMS_IR_API_KEY=
SMS_IR_TEMPLATE_ID=
SMS_IR_PARAM_NAME=Code
SMS_IR_LINE_NUMBER=
# SMS_IR_OTP_MESSAGE=

# --- Admin panel host ---------------------------------------------------------
# UNSET (default): the panel is at /admin.
# SET: the panel is served at the ROOT of this host, and /admin on the main site
# redirects to it. Sessions are host-scoped cookies, so an admin session never
# reaches the storefront.
#
#   ADMIN_HOST=admin.metalgallery.ir
# ADMIN_HOST=

# --- Storefront URL -----------------------------------------------------------
# Used by the panel's "مشاهده فروشگاه" link when the panel runs on its own host.
# Read by a CLIENT component, so Next inlines it AT BUILD TIME — changing it
# requires a rebuild, not a restart.
# NEXT_PUBLIC_SITE_URL=https://metalgallery.ir
